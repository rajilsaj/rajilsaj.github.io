---
import Layout from '~/layouts/Layout.astro'

// ---------------------------------------------------------------------------
// Reading data — edit this to maintain your list.
// `years` is newest-first; each book is { title, author, date }.
// Everything below (counter, stats, bookshelf, list) is generated from this.
// ---------------------------------------------------------------------------
const startYear = 2026

const years: { year: number; books: { title: string; author: string; date: string }[] }[] = [
  {
    year: 2026,
    books: [],
  },
]

const currentlyReading: { title: string; author: string; since: string }[] = []

// --- Derived values -------------------------------------------------------
const allBooks = years.flatMap((y) => y.books)
const totalBooks = allBooks.length
const currentYear = years.length > 0 ? years[0].year : startYear
const hasFinished = totalBooks > 0
const isEmpty = !hasFinished && currentlyReading.length === 0

// Distinct + most-read author.
const authorCounts = new Map<string, number>()
for (const b of allBooks) authorCounts.set(b.author, (authorCounts.get(b.author) ?? 0) + 1)
const distinctAuthors = authorCounts.size
const topAuthor = [...authorCounts.entries()].sort((a, b) => b[1] - a[1])[0]

// Reading cadence: average days between consecutive finishes this year.
const thisYearDates = (years[0]?.books ?? [])
  .map((b) => new Date(b.date).getTime())
  .sort((a, b) => a - b)
let cadence: number | null = null
if (thisYearDates.length > 1) {
  const spanDays = (thisYearDates.at(-1)! - thisYearDates[0]) / 86_400_000
  cadence = Math.round(spanDays / (thisYearDates.length - 1))
}

const stats = [
  { value: String(totalBooks), label: totalBooks === 1 ? 'book' : 'books' },
  { value: String(distinctAuthors), label: distinctAuthors === 1 ? 'author' : 'authors' },
  { value: topAuthor ? topAuthor[0].split(/\s|&/).filter(Boolean).slice(-1)[0] : '—', label: 'most read' },
  { value: cadence ? `${cadence}d` : '—', label: 'avg cadence' },
]

// Deterministic spine height so the shelf is stable between builds (46–92px).
const spineHeight = (title: string) => 46 + ((title.length * 11) % 47)
const shelfBooks = years[0]?.books ?? []

// Year sections: number each year's books in reading order (01 = first read),
// then show newest-first so the latest finish sits on top with the highest #.
const yearSections = years
  .map((y) => {
    const asc = [...y.books].sort((a, b) => a.date.localeCompare(b.date))
    const numbered = asc.map((b, i) => ({ ...b, n: i + 1 }))
    return { year: y.year, books: numbered.reverse() }
  })
  .filter((y) => y.books.length > 0)

// Only show the year jump-nav once there is more than one populated year.
const yearLinks = yearSections.map((y) => y.year)
---

<Layout
  title="Reading"
  description="Every book I have read, logged by year — title, author, and the date I finished."
>
  <header class="mb-10">
    <h1 class="text-2xl font-semibold tracking-tight text-heading1 sm:text-3xl">
      What I have read since {startYear}
    </h1>
    <p class="mt-2 font-mono text-xs text-foreground/45">
      {
        hasFinished ? (
          <>
            // {totalBooks} {totalBooks === 1 ? 'volume' : 'volumes'} ·{' '}
            {distinctAuthors} {distinctAuthors === 1 ? 'author' : 'authors'}
            {cadence && <> · ~{cadence}-day cadence</>}
            {currentlyReading.length > 0 && <> · {currentlyReading.length} in flight</>}
          </>
        ) : currentlyReading.length > 0 ? (
          <>// {currentlyReading.length} in progress · nothing finished yet</>
        ) : (
          <>// reading log · just getting started</>
        )
      }
    </p>

    {/* Stats strip — only meaningful once books are logged */}
    {
      hasFinished && (
        <dl class="mt-6 grid grid-cols-2 overflow-hidden rounded-xl border border-separator sm:grid-cols-4">
          {stats.map((s, i) => (
            <div
              class:list={[
                'px-4 py-3',
                i > 0 && 'sm:border-l sm:border-separator',
                (i === 1 || i === 3) && 'max-sm:border-l max-sm:border-separator',
                i >= 2 && 'max-sm:border-t max-sm:border-separator',
              ]}
            >
              <dd
                class="truncate text-xl font-semibold tracking-tight text-foreground"
                title={s.value}
              >
                {s.value}
              </dd>
              <dt class="mt-0.5 font-mono text-[0.65rem] uppercase tracking-wider text-foreground/45">
                {s.label}
              </dt>
            </div>
          ))}
        </dl>
      )
    }

    {/* Bookshelf */}
    {
      shelfBooks.length > 0 && (
        <div class="mt-6">
          <div class="shelf flex items-end gap-[3px] border-b-2 border-foreground/25 pb-px">
            {shelfBooks.map((b, i) => (
              <a
                href={`#${currentYear}`}
                class="spine group relative block w-[14px] shrink-0 rounded-t-[2px] border border-foreground/25 transition-all hover:-translate-y-1"
                style={`height:${spineHeight(b.title)}px;background-color:color-mix(in srgb, var(--theme-foreground) ${8 + (i % 4) * 4}%, transparent)`}
                aria-label={`${b.title} — ${b.author}`}
              >
                <span class="pointer-events-none absolute bottom-[calc(100%+8px)] left-1/2 z-10 hidden w-max max-w-[14rem] -translate-x-1/2 rounded-md border border-separator bg-background px-2.5 py-1.5 text-xs shadow-sm group-hover:block">
                  <span class="font-medium text-foreground">{b.title}</span>
                  <span class="block text-foreground/55">{b.author}</span>
                </span>
              </a>
            ))}
          </div>
          <p class="mt-2 font-mono text-[0.65rem] text-foreground/35">{currentYear} shelf</p>
        </div>
      )
    }
  </header>

  {/* Currently reading */}
  {
    currentlyReading.length > 0 && (
      <section class="mb-12">
        <h2
          id="currently-reading"
          class="flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-foreground/50"
        >
          <span class="live-dot inline-block size-2 rounded-full bg-green" />
          Currently reading
        </h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {currentlyReading.map((b) => (
            <div class="rounded-xl border border-separator bg-foreground/[0.03] p-4 transition-colors hover:border-foreground/20">
              <p class="font-medium leading-snug text-foreground">{b.title}</p>
              <p class="mt-0.5 text-sm text-foreground/55">{b.author}</p>
              <p class="mt-3 font-mono text-[0.7rem] text-foreground/40">
                started{' '}
                <time datetime={b.since}>{b.since}</time>
              </p>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {/* Year jump-nav (only when more than one year has entries) */}
  {
    yearLinks.length > 1 && (
      <nav class="mb-8 flex flex-wrap items-center gap-2" aria-label="Jump to year">
        {yearLinks.map((y) => (
          <a
            href={`#${y}`}
            class="rounded-md border border-separator px-2.5 py-1 font-mono text-xs text-foreground/60 no-underline transition-colors hover:border-accent/40 hover:text-accent"
          >
            {y}
          </a>
        ))}
      </nav>
    )
  }

  {/* Finished books, by year */}
  {
    hasFinished ? (
      <div class="flex flex-col gap-12">
        {yearSections.map((y) => (
          <section>
            <h2
              id={String(y.year)}
              class="flex items-baseline justify-between border-b border-separator pb-2 font-mono text-sm text-foreground/60"
            >
              <span class="text-base font-semibold tracking-tight text-heading2">{y.year}</span>
              <span class="text-xs text-foreground/40">
                {y.books.length} {y.books.length === 1 ? 'book' : 'books'}
              </span>
            </h2>
            <ol class="mt-1">
              {y.books.map((b) => (
                <li class="group grid grid-cols-[2.2rem_1fr] items-baseline gap-x-3 border-b border-separator/60 py-3 sm:grid-cols-[2.2rem_1fr_auto] sm:gap-x-4">
                  <span class="font-mono text-xs tabular-nums text-foreground/30 transition-colors group-hover:text-accent">
                    {String(b.n).padStart(2, '0')}
                  </span>
                  <div class="min-w-0">
                    <span class="font-medium text-foreground">{b.title}</span>
                    <span class="block text-sm text-foreground/55">{b.author}</span>
                  </div>
                  <time
                    datetime={b.date}
                    class="col-start-2 mt-1 font-mono text-xs tabular-nums text-foreground/40 sm:col-start-3 sm:mt-0 sm:whitespace-nowrap sm:text-right"
                  >
                    {b.date}
                  </time>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-separator px-6 py-16 text-center">
        <svg
          class="mx-auto size-9 text-foreground/25"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v15H6.5A2.5 2.5 0 0 0 4 20.5z" />
          <path d="M4 20.5A2.5 2.5 0 0 1 6.5 18H20" />
        </svg>
        <p class="mt-4 font-medium text-foreground/80">The shelf is empty</p>
        <p class="mx-auto mt-1 max-w-xs text-sm text-foreground/50">
          Nothing logged yet — the first book I finish will show up here, newest first.
        </p>
        <p class="mt-5 font-mono text-[0.7rem] text-foreground/35">
          // add entries in <span class="text-foreground/55">src/pages/reading.astro</span>
        </p>
      </div>
    )
  }

  {/* About */}
  <section class="mt-16 border-t border-separator pt-6">
    <h2
      id="about"
      class="font-mono text-xs uppercase tracking-wider text-foreground/50"
    >
      About this list
    </h2>
    <p class="mt-3 max-w-prose text-sm leading-relaxed text-foreground/60">
      A running log of every book I finish — title, author, and the date I turned
      the last page. I started keeping it in {startYear}. Books are numbered in the
      order I read them and shown newest-first.
    </p>
  </section>
</Layout>

<style>
  /* Soft pulse on the "currently reading" indicator */
  .live-dot {
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--theme-green) 60%, transparent);
    animation: live-pulse 2.4s ease-out infinite;
  }
  @keyframes live-pulse {
    0% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--theme-green) 55%, transparent);
    }
    70% {
      box-shadow: 0 0 0 6px transparent;
    }
    100% {
      box-shadow: 0 0 0 0 transparent;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .live-dot {
      animation: none;
    }
  }
</style>
