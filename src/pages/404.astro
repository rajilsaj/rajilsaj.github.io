---
import Layout from '~/layouts/Layout.astro'
---

<Layout title="404 // access denied">
  <div class="term">
    <div class="scanlines" aria-hidden="true"></div>

    <div class="bar">
      <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      <span class="bar-label">guest@rajil — /dev/null</span>
    </div>

    <pre class="glitch" data-text="404" aria-label="404">404</pre>

    <div class="log">
      <p>
        <span class="prompt">guest@rajil:~$</span> cat <span class="path">/unknown</span>
      </p>
      <p class="err">
        ✗ ERROR 404 — segmentation fault: page not found in this timeline
      </p>
      <p class="typed">&gt; trace: the resource you requested does not exist…</p>
      <p>
        <span class="prompt">guest@rajil:~$</span>
        <span class="cursor">█</span>
      </p>
    </div>

    <div class="actions">
      <a href="/">$ cd ~</a>
      <a href="/posts">$ ls /blog</a>
    </div>
  </div>
</Layout>

<script is:inline>
  const el = document.querySelector('.term .path')
  if (el) el.textContent = location.pathname || '/unknown'
</script>

<style>
  .term {
    position: relative;
    overflow: hidden;
    margin: 1rem 0 2rem;
    min-height: 58vh;
    border-radius: 0.75rem;
    border: 1px solid rgba(0, 255, 95, 0.25);
    background: #06090a;
    color: #46f08a;
    font-family: var(--default-mono-font-family);
    box-shadow:
      0 0 0 1px rgba(0, 255, 95, 0.05),
      0 0 40px rgba(0, 255, 95, 0.08) inset;
    padding: 0 1.25rem 1.75rem;
  }

  .bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 -1.25rem 1.5rem;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid rgba(0, 255, 95, 0.18);
    background: rgba(0, 255, 95, 0.04);
  }
  .dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 9999px;
    background: rgba(0, 255, 95, 0.4);
  }
  .bar-label {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: rgba(70, 240, 138, 0.55);
  }

  /* Glitchy 404 */
  .glitch {
    position: relative;
    margin: 1.5rem 0 1rem;
    font-size: clamp(4rem, 22vw, 9rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0.05em;
    color: #7dffae;
    text-shadow: 0 0 12px rgba(0, 255, 95, 0.5);
  }
  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    background: #06090a;
    overflow: hidden;
  }
  .glitch::before {
    left: 2px;
    text-shadow: -2px 0 #ff003c;
    clip-path: inset(0 0 55% 0);
    animation: glitch-top 2.2s infinite linear alternate;
  }
  .glitch::after {
    left: -2px;
    text-shadow: -2px 0 #00e5ff;
    clip-path: inset(55% 0 0 0);
    animation: glitch-bot 1.8s infinite linear alternate;
  }
  @keyframes glitch-top {
    0% { transform: translate(0); }
    20% { transform: translate(-3px, -1px); }
    40% { transform: translate(2px, 1px); }
    60% { transform: translate(-2px, 0); }
    80% { transform: translate(3px, 1px); }
    100% { transform: translate(0); }
  }
  @keyframes glitch-bot {
    0% { transform: translate(0); }
    25% { transform: translate(2px, 1px); }
    50% { transform: translate(-3px, -1px); }
    75% { transform: translate(1px, 1px); }
    100% { transform: translate(0); }
  }

  .log {
    font-size: 0.9rem;
    line-height: 1.9;
  }
  .log p {
    margin: 0;
  }
  .prompt {
    color: #2bd66f;
  }
  .err {
    color: #ff5470;
  }
  .path {
    color: #7dffae;
  }

  /* Typewriter line */
  .typed {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid transparent;
    width: 0;
    max-width: 100%;
    animation: typing 2.6s steps(48, end) 0.4s forwards;
  }
  @keyframes typing {
    to { width: 46ch; }
  }

  .cursor {
    animation: blink 1.05s step-end infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  .actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .actions a {
    color: #46f08a;
    text-decoration: none;
    border: 1px solid rgba(0, 255, 95, 0.35);
    border-radius: 0.5rem;
    padding: 0.4rem 0.9rem;
    transition:
      background-color 0.15s ease,
      box-shadow 0.15s ease;
  }
  .actions a:hover {
    background: rgba(0, 255, 95, 0.12);
    box-shadow: 0 0 16px rgba(0, 255, 95, 0.25);
  }

  /* CRT scanlines */
  .scanlines {
    pointer-events: none;
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      rgba(0, 255, 95, 0.05) 0,
      rgba(0, 255, 95, 0.05) 1px,
      transparent 2px,
      transparent 4px
    );
    mix-blend-mode: screen;
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch::before,
    .glitch::after,
    .typed,
    .cursor {
      animation: none;
    }
    .typed {
      width: auto;
    }
  }
</style>
