---
import Layout from '~/layouts/Layout.astro'
import { getSortedPosts } from '~/utils'
import { getCollection, render } from 'astro:content'
import { Image } from 'astro:assets'
import PostPreview from '~/components/PostPreview.astro'
import profile0 from '~/content/profile-0.jpg'
import profile1 from '~/content/profile-1.jpg'
import profile2 from '~/content/profile-2.jpg'
import profile3 from '~/content/profile-3.jpg'

const home = await getCollection('home')
let HomeContent
if (home.length > 0) {
  const { Content } = await render(home[0])
  HomeContent = Content
}

const avatars = [
  { src: profile0, alt: 'Rajil at his graduation' },
  { src: profile1, alt: 'Rajil at NASA JPL' },
  { src: profile2, alt: 'Rajil in a Superheroes of Science beanie' },
  { src: profile3, alt: 'Rajil in a tan jacket' },
]

const sortedPosts = await getSortedPosts()
const recentPosts = sortedPosts.reverse().slice(0, 5)
---

<Layout>
  <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:gap-7">
    <div class="avatar-wrap relative shrink-0">
      <div
        class="avatar-cycle relative size-28 overflow-hidden rounded-full ring-1 ring-foreground/15 sm:size-32"
      >
        {
          avatars.map((a) => (
            <Image
              src={a.src}
              alt={a.alt}
              widths={[128, 256]}
              height={128}
              width={128}
              class="absolute inset-0 size-full object-cover"
            />
          ))
        }
      </div>
      <div class="avatar-ring" aria-hidden="true"></div>
    </div>
    <div class="prose max-w-none">
      {HomeContent && <HomeContent />}
    </div>
  </div>

  {
    recentPosts.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-4 text-lg font-semibold">Posts</h2>
        <div class="flex flex-col">
          {recentPosts.map((post) => (
            <PostPreview post={post} />
          ))}
        </div>
        <p class="mt-5 text-sm">
          <a href="/posts" class="no-underline hover:underline">
            → all posts
          </a>
        </p>
      </section>
    )
  }
</Layout>

<style is:global>
  a.heading-anchor {
    display: none !important;
  }
</style>

<style>
  /* "Charging" loading ring that fills around the circle on hover */
  @property --ring-progress {
    syntax: '<percentage>';
    inherits: false;
    initial-value: 0%;
  }
  .avatar-ring {
    position: absolute;
    inset: -6px;
    border-radius: 9999px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    background: conic-gradient(
      from -90deg,
      var(--theme-foreground) var(--ring-progress, 0%),
      color-mix(in oklab, var(--theme-foreground) 10%, transparent) 0
    );
    -webkit-mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 3px),
      #000 calc(100% - 3px)
    );
    mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 3px),
      #000 calc(100% - 3px)
    );
  }
  .avatar-wrap:hover .avatar-ring {
    opacity: 1;
    animation: ring-charge 4s linear infinite;
  }
  @keyframes ring-charge {
    from {
      --ring-progress: 0%;
    }
    to {
      --ring-progress: 100%;
    }
  }

  /* Hover to cross-fade through the photos */
  .avatar-cycle img {
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .avatar-cycle img:nth-child(1) {
    opacity: 1;
  }
  .avatar-cycle:hover img {
    animation: avatar-cycle 4s infinite;
  }
  .avatar-cycle:hover img:nth-child(1) {
    animation-delay: -0.5s;
  }
  .avatar-cycle:hover img:nth-child(2) {
    animation-delay: 0.5s;
  }
  .avatar-cycle:hover img:nth-child(3) {
    animation-delay: 1.5s;
  }
  .avatar-cycle:hover img:nth-child(4) {
    animation-delay: 2.5s;
  }
  @keyframes avatar-cycle {
    0% {
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    25% {
      opacity: 1;
    }
    33% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .avatar-cycle:hover img,
    .avatar-wrap:hover .avatar-ring {
      animation: none;
    }
  }
</style>
