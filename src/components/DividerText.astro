---
interface Props {
  text: string
}
const { text } = Astro.props
---

<div class="my-10 flex items-center gap-4 text-sm text-foreground/55">
  <hr class="h-px flex-1 border-0 bg-separator" />
  <span class="shrink-0 whitespace-nowrap">{text}</span>
  <hr class="h-px flex-1 border-0 bg-separator" />
</div>
