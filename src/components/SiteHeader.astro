---
import siteConfig from '~/site.config'

interface Props {
  title?: string
}
const { title } = Astro.props

const path = Astro.url.pathname.replace(/\/+$/, '') || '/'
const segs = path.replace(/^\/|\/$/g, '').split('/').filter(Boolean)
const isActive = (url: string) =>
  url === '/' ? path === '/' : path === url || path.startsWith(url + '/')
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1)

// Terminal-style breadcrumb: / Site / Section / Page
type Crumb = { label: string; href?: string }
const crumbs: Crumb[] = [{ label: siteConfig.title, href: '/' }]
if (segs.length) {
  if (segs[0] === 'posts') {
    const onArchive = segs.length === 1 || /^\d+$/.test(segs[1])
    crumbs.push({ label: 'Blog', href: onArchive ? undefined : '/posts' })
    if (!onArchive) crumbs.push({ label: title ?? segs[segs.length - 1] })
  } else if (segs[0] === 'tags') {
    crumbs.push({ label: 'Tags' })
    if (segs[1]) crumbs.push({ label: '#' + decodeURIComponent(segs[1]) })
  } else {
    crumbs.push({ label: title ?? cap(segs[0]) })
  }
}
---

<header class="mb-10 border-b border-separator pb-4">
  <nav class="overflow-x-auto whitespace-nowrap text-sm" aria-label="Breadcrumb">
    <ol class="flex items-center">
      {
        crumbs.map((c) => (
          <li class="flex items-center">
            <span class="mx-1.5 text-foreground/35 select-none">/</span>
            {c.href ? (
              <a href={c.href} class="text-foreground/60 no-underline hover:text-foreground hover:underline decoration-dotted">
                {c.label}
              </a>
            ) : (
              <span class="font-semibold text-foreground">{c.label}</span>
            )}
          </li>
        ))
      }
    </ol>
  </nav>

  <nav class="mt-3 flex flex-wrap gap-x-5 gap-y-1 text-sm" aria-label="Main">
    {
      siteConfig.navLinks.map((link) => (
        <a
          href={link.url}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noreferrer noopener' : undefined}
          aria-current={isActive(link.url) ? 'page' : undefined}
          class:list={[
            'no-underline decoration-dotted hover:underline',
            isActive(link.url)
              ? 'font-semibold text-foreground underline'
              : 'text-foreground/55 hover:text-foreground',
          ]}
        >
          {link.name.toLowerCase()}
        </a>
      ))
    }
  </nav>
</header>
