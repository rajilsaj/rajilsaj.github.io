---
import siteConfig from '~/site.config'
import IconLinkedin from '~/icons/linkedin.svg'
import IconTwitter from '~/icons/twitter.svg'

const path = Astro.url.pathname.replace(/\/+$/, '') || '/'
const isActive = (url: string) =>
  url === '/' ? path === '/' : path === url || path.startsWith(url + '/')
const linkedin = siteConfig.socialLinks?.linkedin
const twitter = siteConfig.socialLinks?.twitter
---

<header
  class="sticky top-0 z-40 -mx-5 mb-12 bg-background/85 px-5 py-3.5 backdrop-blur sm:-mx-6 sm:px-6"
>
  <div class="flex items-center justify-between gap-4">
    <a
      href="/"
      class="font-semibold tracking-tight text-foreground no-underline hover:text-foreground"
    >
      {siteConfig.title}
    </a>

    <nav class="flex items-center gap-5 text-sm" aria-label="Primary">
      {
        siteConfig.navLinks.map((link) => (
          <a
            href={link.url}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noreferrer noopener' : undefined}
            aria-current={isActive(link.url) ? 'page' : undefined}
            class:list={[
              'no-underline transition-colors hover:text-foreground',
              isActive(link.url)
                ? 'font-medium text-foreground'
                : 'text-foreground/55',
            ]}
          >
            {link.name}
          </a>
        ))
      }

      {
        (twitter || linkedin) && (
          <span class="mx-0.5 h-4 w-px bg-separator" aria-hidden="true" />
        )
      }
      {
        twitter && (
          <a
            href={twitter}
            target="_blank"
            rel="noreferrer noopener"
            aria-label="X (Twitter)"
            class="text-foreground/55 no-underline transition-colors hover:text-foreground"
          >
            <IconTwitter class="size-4.5" />
          </a>
        )
      }
      {
        linkedin && (
          <a
            href={linkedin}
            target="_blank"
            rel="noreferrer noopener"
            aria-label="LinkedIn"
            class="text-foreground/55 no-underline transition-colors hover:text-foreground"
          >
            <IconLinkedin class="size-4.5" />
          </a>
        )
      }
    </nav>
  </div>
</header>
