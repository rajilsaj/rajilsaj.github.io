---
import type { CollectionEntry } from 'astro:content'
import { dateString } from '~/utils'

interface Props {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props
const href = `/posts/${post.id}`
---

<div
  class="grid grid-cols-1 gap-x-5 py-1.5 sm:grid-cols-[7.5rem_1fr] sm:items-baseline"
>
  <time datetime={post.data.published.toISOString()} class="text-sm text-foreground/45">
    {dateString(post.data.published)}
  </time>
  <a href={href} class="no-underline hover:underline decoration-dotted">
    {post.data.title}
  </a>
</div>
