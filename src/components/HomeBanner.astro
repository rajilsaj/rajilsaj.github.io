---
import { Image } from 'astro:assets'
import GitHubActivityCalendar from '~/components/GitHubActivityCalendar.astro'
import type { FrontmatterImage } from '~/types'
import profile0 from '~/content/profile-0.jpg'
import profile1 from '~/content/profile-1.jpg'
import profile2 from '~/content/profile-2.jpg'
import profile3 from '~/content/profile-3.jpg'

interface Props {
  avatarImage?: FrontmatterImage
  githubCalendar?: string
}
const { githubCalendar } = Astro.props

const avatars = [
  { src: profile0, alt: 'Rajil at his graduation' },
  { src: profile1, alt: 'Rajil at NASA JPL' },
  { src: profile2, alt: 'Rajil in a Superheroes of Science beanie' },
  { src: profile3, alt: 'Rajil in a tan jacket' },
]
---

<div class="my-6 md:mx-2">
  <!-- Terminal-window card (interactive — navigate the whole site from here) -->
  <div
    id="home-terminal-card"
    class="home-terminal relative overflow-hidden rounded-2xl border border-foreground/10 bg-foreground/[0.03] font-mono text-sm shadow-2xl backdrop-blur-sm"
  >
    <!-- Title bar -->
    <div
      class="flex items-center gap-2 border-b border-foreground/10 bg-foreground/[0.04] px-4 py-2.5"
    >
      <span class="size-3 rounded-full bg-red/80"></span>
      <span class="size-3 rounded-full bg-yellow/80"></span>
      <span class="size-3 rounded-full bg-green/80"></span>
      <span class="ml-3 text-xs text-foreground/45 select-none">~/rajil — zsh</span>
    </div>

    <!-- Body -->
    <div
      class="flex flex-col items-center gap-6 px-6 py-8 sm:flex-row sm:items-start sm:gap-8 sm:px-9 sm:py-9"
    >
      <div class="avatar-glow relative shrink-0">
        <div
          class="avatar-cycle relative size-44 overflow-hidden rounded-full ring-2 ring-accent/60 sm:size-56"
        >
          {
            avatars.map((a) => (
              <Image
                src={a.src}
                alt={a.alt}
                widths={[288]}
                height={144}
                width={144}
                class="absolute inset-0 size-full object-cover"
              />
            ))
          }
        </div>
        <div class="avatar-ring" aria-hidden="true"></div>
      </div>

      <div class="flex min-w-0 flex-1 flex-col self-stretch">
        <!-- Seeded session output; new command output is appended below -->
        <div
          data-term-output
          class="max-h-72 flex-1 space-y-0.5 overflow-y-auto leading-relaxed text-foreground/90"
        >
          <div>
            <span class="text-green">rajil@web:~$</span> whoami
          </div>
          <div class="prose mt-1 max-w-full">
            <slot />
          </div>
        </div>

        <!-- Live input line -->
        <form data-term-form class="mt-4 flex items-center gap-2">
          <span data-term-prompt class="shrink-0 whitespace-nowrap text-green">
            rajil@web:~$
          </span>
          <input
            data-term-input
            type="text"
            autocomplete="off"
            autocapitalize="off"
            spellcheck="false"
            aria-label="Terminal command input"
            class="min-w-0 flex-1 border-none bg-transparent text-foreground outline-none"
          />
        </form>

        <div data-term-hint class="mt-3 text-xs text-foreground/50"></div>
      </div>
    </div>
  </div>

  <!-- {githubCalendar && <GitHubActivityCalendar username={githubCalendar} />} -->
</div>

<script>
  import { mountTerminal } from '../scripts/terminalEngine'

  function initHomeTerminal() {
    const card = document.getElementById('home-terminal-card')
    if (card) mountTerminal(card)
  }

  initHomeTerminal()
  document.addEventListener('astro:page-load', initHomeTerminal)
</script>

<style>
  /* --- Cycling avatar -------------------------------------------------- */
  /* Stack of photos; first one shown by default, the rest fade in only
     while the circle is hovered, looping for as long as the cursor stays. */
  .avatar-cycle img {
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .avatar-cycle img:nth-child(1) {
    opacity: 1;
  }

  .avatar-cycle:hover img {
    animation: avatar-cycle 4s infinite;
  }
  /* Negative offset on the first image keeps it visible at hover-start
     (no flash); the 1s spacing across 4 photos gives an even rotation. */
  .avatar-cycle:hover img:nth-child(1) {
    animation-delay: -0.5s;
  }
  .avatar-cycle:hover img:nth-child(2) {
    animation-delay: 0.5s;
  }
  .avatar-cycle:hover img:nth-child(3) {
    animation-delay: 1.5s;
  }
  .avatar-cycle:hover img:nth-child(4) {
    animation-delay: 2.5s;
  }

  @keyframes avatar-cycle {
    0% {
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    25% {
      opacity: 1;
    }
    33% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  /* --- "Charging" progress ring --------------------------------------- */
  /* A thin accent ring that fills 0 -> 360deg over one full photo cycle,
     visible only while hovering, so it reads like the photos are loading. */
  @property --ring-progress {
    syntax: '<percentage>';
    inherits: false;
    initial-value: 0%;
  }

  .avatar-ring {
    position: absolute;
    inset: -7px;
    border-radius: 9999px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    background: conic-gradient(
      from -90deg,
      var(--theme-accent) var(--ring-progress, 0%),
      color-mix(in oklab, var(--theme-accent) 12%, transparent) 0
    );
    /* Carve out the center so only a thin ring shows */
    -webkit-mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 4px),
      #000 calc(100% - 4px)
    );
    mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 4px),
      #000 calc(100% - 4px)
    );
  }

  .avatar-glow:hover .avatar-ring {
    opacity: 1;
    animation: ring-charge 4s linear infinite;
  }

  @keyframes ring-charge {
    from {
      --ring-progress: 0%;
    }
    to {
      --ring-progress: 100%;
    }
  }

  /* --- Glow behind the avatar ----------------------------------------- */
  .avatar-glow::before {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 9999px;
    background: radial-gradient(
      circle,
      color-mix(in oklab, var(--theme-accent) 45%, transparent),
      transparent 70%
    );
    filter: blur(14px);
    z-index: -1;
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%,
    100% {
      opacity: 0.55;
      transform: scale(1);
    }
    50% {
      opacity: 0.9;
      transform: scale(1.06);
    }
  }

  /* Soft accent wash in the top-right of the card */
  .home-terminal::after {
    content: '';
    position: absolute;
    top: -40%;
    right: -20%;
    width: 60%;
    height: 120%;
    background: radial-gradient(
      circle,
      color-mix(in oklab, var(--theme-accent) 14%, transparent),
      transparent 65%
    );
    pointer-events: none;
  }

  .cursor {
    display: inline-block;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-glow::before,
    .cursor,
    .avatar-cycle:hover img,
    .avatar-glow:hover .avatar-ring {
      animation: none;
    }
  }
</style>
