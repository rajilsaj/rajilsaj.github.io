---
import { Image } from 'astro:assets'
import type { FrontmatterImage } from '~/types'
import profile0 from '~/content/profile-0.jpg'
import profile1 from '~/content/profile-1.jpg'
import profile2 from '~/content/profile-2.jpg'
import profile3 from '~/content/profile-3.jpg'

interface Props {
  avatarImage?: FrontmatterImage
  githubCalendar?: string
}

const avatars = [
  { src: profile0, alt: 'Rajil at his graduation' },
  { src: profile1, alt: 'Rajil at NASA JPL' },
  { src: profile2, alt: 'Rajil in a Superheroes of Science beanie' },
  { src: profile3, alt: 'Rajil in a tan jacket' },
]
---

<!-- whoami output: avatar + bio, rendered as terminal output by the shell -->
<div
  class="flex flex-col items-center gap-6 sm:flex-row sm:items-center sm:gap-8"
>
  <div class="avatar-glow relative shrink-0">
    <div
      class="avatar-cycle relative size-44 overflow-hidden rounded-full ring-2 ring-accent/60 sm:size-52"
    >
      {
        avatars.map((a) => (
          <Image
            src={a.src}
            alt={a.alt}
            widths={[288]}
            height={144}
            width={144}
            class="absolute inset-0 size-full object-cover"
          />
        ))
      }
    </div>
    <div class="avatar-ring" aria-hidden="true"></div>
  </div>

  <div class="prose min-w-0 max-w-full flex-1">
    <slot />
  </div>
</div>

<style>
  /* --- Cycling avatar -------------------------------------------------- */
  .avatar-cycle img {
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .avatar-cycle img:nth-child(1) {
    opacity: 1;
  }

  .avatar-cycle:hover img {
    animation: avatar-cycle 4s infinite;
  }
  .avatar-cycle:hover img:nth-child(1) {
    animation-delay: -0.5s;
  }
  .avatar-cycle:hover img:nth-child(2) {
    animation-delay: 0.5s;
  }
  .avatar-cycle:hover img:nth-child(3) {
    animation-delay: 1.5s;
  }
  .avatar-cycle:hover img:nth-child(4) {
    animation-delay: 2.5s;
  }

  @keyframes avatar-cycle {
    0% {
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    25% {
      opacity: 1;
    }
    33% {
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  /* --- "Charging" progress ring --------------------------------------- */
  @property --ring-progress {
    syntax: '<percentage>';
    inherits: false;
    initial-value: 0%;
  }

  .avatar-ring {
    position: absolute;
    inset: -7px;
    border-radius: 9999px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    background: conic-gradient(
      from -90deg,
      var(--theme-accent) var(--ring-progress, 0%),
      color-mix(in oklab, var(--theme-accent) 12%, transparent) 0
    );
    -webkit-mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 4px),
      #000 calc(100% - 4px)
    );
    mask: radial-gradient(
      farthest-side,
      transparent calc(100% - 4px),
      #000 calc(100% - 4px)
    );
  }

  .avatar-glow:hover .avatar-ring {
    opacity: 1;
    animation: ring-charge 4s linear infinite;
  }

  @keyframes ring-charge {
    from {
      --ring-progress: 0%;
    }
    to {
      --ring-progress: 100%;
    }
  }

  /* --- Glow behind the avatar ----------------------------------------- */
  .avatar-glow::before {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 9999px;
    background: radial-gradient(
      circle,
      color-mix(in oklab, var(--theme-accent) 45%, transparent),
      transparent 70%
    );
    filter: blur(14px);
    z-index: -1;
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%,
    100% {
      opacity: 0.55;
      transform: scale(1);
    }
    50% {
      opacity: 0.9;
      transform: scale(1.06);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-glow::before,
    .avatar-cycle:hover img,
    .avatar-glow:hover .avatar-ring {
      animation: none;
    }
  }
</style>
