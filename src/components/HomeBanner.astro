---
import { Image } from 'astro:assets'
import GitHubActivityCalendar from '~/components/GitHubActivityCalendar.astro'
import type { FrontmatterImage } from '~/types'

interface Props {
  avatarImage?: FrontmatterImage
  githubCalendar?: string
}
const { avatarImage, githubCalendar } = Astro.props
---

<div class="my-6 md:mx-2">
  <!-- Terminal-window card -->
  <div
    class="home-terminal relative overflow-hidden rounded-2xl border border-foreground/10 bg-foreground/[0.03] shadow-2xl backdrop-blur-sm"
  >
    <!-- Title bar -->
    <div
      class="flex items-center gap-2 border-b border-foreground/10 bg-foreground/[0.04] px-4 py-2.5"
    >
      <span class="size-3 rounded-full bg-red/80"></span>
      <span class="size-3 rounded-full bg-yellow/80"></span>
      <span class="size-3 rounded-full bg-green/80"></span>
      <span class="ml-3 text-xs text-foreground/45 select-none">~/rajil — zsh</span>
    </div>

    <!-- Body -->
    <div
      class="flex flex-col items-center gap-6 px-6 py-8 sm:flex-row sm:items-center sm:gap-8 sm:px-9 sm:py-9"
    >
      {
        avatarImage && (
          <div class="avatar-glow relative shrink-0">
            <Image
              priority
              src={avatarImage.src}
              alt={avatarImage.alt}
              class="relative size-32 rounded-full object-cover ring-2 ring-accent/60 sm:size-36"
              widths={[288]}
              height={144}
              width={144}
            />
          </div>
        )
      }

      <div class="min-w-0 flex-1">
        <p class="mb-3 font-mono text-sm text-foreground/55">
          <span class="text-green">❯</span>
          <span class="text-accent">whoami</span>
        </p>
        <div class="prose max-w-full">
          <slot />
        </div>
        <p class="mt-4 font-mono text-sm text-foreground/55">
          <span class="text-green">❯</span>
          <span class="cursor">█</span>
        </p>
      </div>
    </div>
  </div>

  <!-- {githubCalendar && <GitHubActivityCalendar username={githubCalendar} />} -->
</div>

<style>
  /* Subtle animated glow behind the avatar, tinted by the active theme accent */
  .avatar-glow::before {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 9999px;
    background: radial-gradient(
      circle,
      color-mix(in oklab, var(--theme-accent) 45%, transparent),
      transparent 70%
    );
    filter: blur(14px);
    z-index: -1;
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%,
    100% {
      opacity: 0.55;
      transform: scale(1);
    }
    50% {
      opacity: 0.9;
      transform: scale(1.06);
    }
  }

  /* Soft accent wash in the top-right of the card */
  .home-terminal::after {
    content: '';
    position: absolute;
    top: -40%;
    right: -20%;
    width: 60%;
    height: 120%;
    background: radial-gradient(
      circle,
      color-mix(in oklab, var(--theme-accent) 14%, transparent),
      transparent 65%
    );
    pointer-events: none;
  }

  .cursor {
    display: inline-block;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-glow::before,
    .cursor {
      animation: none;
    }
  }
</style>
